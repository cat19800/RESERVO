# Database (Postgres via docker-compose)
DATABASE_URL="postgresql://reservo:reservo@localhost:5433/reservo?schema=public"

# Auth — REPLACE in real environments. 32+ random chars.
JWT_SECRET="dev-secret-change-me-32-chars-min-aaaaaa"

# Stub modes (UC8 reminders, UC9 payments)
# always-succeed | always-fail | random
BANK_STUB_MODE="always-succeed"
SMS_STUB_MODE="always-succeed"

# Dev tools (admin trigger pages, seed reset)
# 1 = enabled, 0 = disabled
DEV_TOOLS="1"

# Cron expression for the reminder tick (every minute by default)
REMINDER_CRON_EXPR="*/1 * * * *"

# Time zone for displaying schedules (Europe/Athens)
APP_TZ="Europe/Athens"

# Localization
NEXT_PUBLIC_DEFAULT_LOCALE="el"
