// Prisma 7 schema (see PLAN.md §4.5).
// Generator uses the new `prisma-client` provider with explicit output.
// Datasource URL is configured in prisma.config.ts at the project root.

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// =========== AUTH SHELL ===========
// Shared identity table. Customer and Professional both reference one User.
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String // bcrypt hash
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile              Profile?
  notificationSettings NotificationSettings?
  customer             Customer?
  professional         Professional?
  notifications        Notification[]        @relation("UserNotifications")
}

// =========== DOMAIN: PROFILE ===========
model Profile {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName  String
  lastName   String
  phone      String?
  city       String?
  address    String?
  bio        String?
  avatarSeed String // deterministic Dicebear seed; defaults to email
  updatedAt  DateTime @updatedAt
}

// =========== DOMAIN: NOTIFICATION SETTINGS ===========
model NotificationSettings {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inAppEnabled  Boolean  @default(true)
  emailEnabled  Boolean  @default(true)
  smsEnabled    Boolean  @default(true)
  pushEnabled   Boolean  @default(true)
  reminderHours Int      @default(24)
  updatedAt     DateTime @updatedAt
}

// =========== DOMAIN: CUSTOMER ===========
model Customer {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  appointments Appointment[]
  reviews      Review[]
}

// =========== DOMAIN: PROFESSIONAL ===========
enum Category {
  DOCTOR
  GYM
  HAIR_SALON
  BEAUTY_CARE
}

model Professional {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String
  category    Category
  specialty   String?
  description String?
  city        String
  address     String
  ratingAvg   Float    @default(0)
  ratingCount Int      @default(0)
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  schedule          Schedule?
  cancellationRules CancellationRules?
  services          Service[]
  appointments      Appointment[]
  reviews           Review[]
  subscription      Subscription?

  @@index([category, city])
  @@index([ratingAvg])
}

// =========== DOMAIN: COMPANY ===========
model Company {
  id          String   @id @default(uuid())
  name        String   @unique
  category    Category
  city        String
  address     String
  phone       String?
  email       String?
  description String?
  createdAt   DateTime @default(now())

  professionals Professional[]
}

// =========== DOMAIN: SERVICE ===========
model Service {
  id              String       @id @default(uuid())
  professionalId  String
  professional    Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  durationMinutes Int // e.g. 30, 45, 60
  priceCents      Int // EUR cents
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  appointments Appointment[]

  @@unique([professionalId, name]) // UC6 alt-flow 2: no duplicates
  @@index([professionalId, active])
}

// =========== DOMAIN: SCHEDULE ===========
model Schedule {
  id                     String       @id @default(uuid())
  professionalId         String       @unique
  professional           Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  slotGranularityMinutes Int          @default(15) // grid step for offering slots
  bufferMinutes          Int          @default(0) // gap between appts
  updatedAt              DateTime     @updatedAt

  workingHours   WorkingHours[]
  blockedPeriods BlockedPeriod[]
}

model WorkingHours {
  id         String   @id @default(uuid())
  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  dayOfWeek  Int // 0 = Sunday … 6 = Saturday
  startTime  String // "09:00" stored as HH:mm string in pro's local tz
  endTime    String // "17:00"

  @@index([scheduleId, dayOfWeek])
}

model BlockedPeriod {
  id         String   @id @default(uuid())
  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  startsAt   DateTime
  endsAt     DateTime
  reason     String?
  createdAt  DateTime @default(now())

  @@index([scheduleId, startsAt])
}

// =========== DOMAIN: CANCELLATION RULES ===========
model CancellationRules {
  id             String       @id @default(uuid())
  professionalId String       @unique
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  deadlineHours  Int          @default(24)
  feeCents       Int? // future use; v1 always null
  updatedAt      DateTime     @updatedAt
}

// =========== DOMAIN: APPOINTMENT ===========
enum AppointmentStatus {
  HELD // tentative; expires at tentativeUntil
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum CancelledBy {
  CUSTOMER
  PROFESSIONAL
  SYSTEM
}

model Appointment {
  id             String       @id @default(uuid())
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id])
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])
  serviceId      String
  service        Service      @relation(fields: [serviceId], references: [id])

  startsAt           DateTime
  endsAt             DateTime
  status             AppointmentStatus @default(HELD)
  tentativeUntil     DateTime?
  cancelledAt        DateTime?
  cancelledBy        CancelledBy?
  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review            Review?
  notifications     Notification[]
  reminderHistories ReminderHistory[]

  @@index([customerId, startsAt])
  @@index([professionalId, startsAt])
  @@index([status, tentativeUntil])
  @@index([status, endsAt]) // for the "find past CONFIRMED to mark COMPLETED" sweep
  // The slot-uniqueness partial unique index lives in
  // prisma/migrations/<phase6>/migration.sql (Prisma can't express it).
}

// =========== DOMAIN: SUBSCRIPTION (UC9) ===========
enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum SubscriptionPlan {
  PREMIUM_MONTHLY
}

model Subscription {
  id             String             @id @default(uuid())
  professionalId String             @unique
  professional   Professional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  plan           SubscriptionPlan   @default(PREMIUM_MONTHLY)
  status         SubscriptionStatus
  startedAt      DateTime           @default(now())
  expiresAt      DateTime
  cancelledAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  payments PaymentRecord[]

  @@index([status, expiresAt])
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
}

model PaymentRecord {
  id             String        @id @default(uuid())
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amountCents    Int
  currency       String        @default("EUR")
  status         PaymentStatus
  bankRef        String?
  errorMessage   String?
  cardLast4      String
  createdAt      DateTime      @default(now())

  @@index([subscriptionId, createdAt])
}

// =========== DOMAIN: REMINDER HISTORY ===========
// Audit trail for the reminder cron (UC8). One row per (appointment, channel)
// — the unique index makes `runReminderTick` idempotent: re-running the tick
// after a successful send is a no-op for that (appointment, channel) pair.
model ReminderHistory {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  channel       String // 'in-app' | 'sms-stub'
  status        String // 'sent' | 'failed'
  sentAt        DateTime    @default(now())
  meta          Json // { messageBody?, error? }

  @@unique([appointmentId, channel])
  @@index([sentAt])
}

// =========== DOMAIN: REVIEW ===========
model Review {
  id             String       @id @default(uuid())
  appointmentId  String       @unique // 1-1 with Appointment per UC4
  appointment    Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id])
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])
  rating         Int // 1-5; validated by zod
  comment        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([professionalId, createdAt])
}

// =========== DOMAIN: NOTIFICATION ===========
enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
  REMINDER
  REVIEW_REQUEST
  PAYMENT_RECEIPT
  SCHEDULE_CONFLICT_CANCELLED
  COMPANY_CREATED
  PREMIUM_ACTIVATED
}

model Notification {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment?     @relation(fields: [appointmentId], references: [id])
  type          NotificationType
  titleKey      String // i18n key
  bodyKey       String // i18n key
  payload       Json // template variables
  readAt        DateTime?
  createdAt     DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}
